# Oracle connection
ORACLE_HOST=oracle-host
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=ORCL
ORACLE_USER=app_user
ORACLE_PASSWORD=app_password

# Export source
EXPORT_TABLE=APP_OWNER.APP_LOGS
EXPORT_TIMESTAMP_COLUMN=CREATED_AT
EXPORT_IGNORED_COLUMNS=RAW_PAYLOAD,DEBUG_TEXT
EXPORT_ADDITIONAL_WHERE=

# Polling and batch
EXPORT_POLL_INTERVAL_SECONDS=300
EXPORT_FETCH_BATCH_SIZE=5000
EXPORT_INITIAL_LOOKBACK_MINUTES=5

# Output and state (inside container)
EXPORT_OUTPUT_DIR=/app/output
EXPORT_OUTPUT_PREFIX=oracle-log
EXPORT_STATE_FILE=/app/state/export-state.json

# Docker Environment variables should be defined in .env file, not here. This is just an example template.
GHCR_TAG=1.0.0